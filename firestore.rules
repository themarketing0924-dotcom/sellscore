rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, create: if isOwner(uid);
      // plan/planExpiresAt는 결제 승인(confirmTossPayment, Admin SDK)만 쓸 수 있다 —
      // 클라이언트가 결제 없이 스스로 플랜을 부여하지 못하도록 막는다.
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'planExpiresAt']);
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get, list, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /subscriptions/{subId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow get, list, update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // 토스 결제 기록. 결제창을 열기 전 클라이언트가 status:'pending'으로만
    // 미리 만들 수 있고, 'approved'/'failed'로의 전환은 confirmTossPayment
    // 함수(Admin SDK, 규칙 우회)만 할 수 있다 — 클라이언트가 스스로 결제를
    // "승인됨"으로 조작하지 못하게 막는 것이 핵심.
    match /payments/{orderId} {
      allow get, list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    // 공유 링크(/diagnose/report/:id)로 누구나 단건 조회 가능, 목록 열람("내 리포트")은 본인 것만.
    // paidUnlocked는 생성 시 반드시 false여야 한다 — 결제 없이 스스로 리포트를
    // "결제됨" 상태로 만들어 저장하는 걸 막는다. true로의 전환은 결제 승인
    // 함수(Admin SDK)만 할 수 있다.
    match /reports/{reportId} {
      allow get: if true;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.paidUnlocked == false;
      allow update, delete: if false;
    }

    // 코드→소유자 매핑은 초대 링크 진입 시 비로그인 상태에서도 조회 가능해야 한다.
    match /referralCodes/{code} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    // 문서 ID = 초대받은 사람의 uid. 본인 또는 초대 코드 소유자만 열람 가능.
    match /referrals/{referredUid} {
      allow get: if request.auth != null &&
        (request.auth.uid == referredUid || resource.data.ownerUid == request.auth.uid);
      allow list: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null &&
        request.auth.uid == referredUid && request.resource.data.referredUid == referredUid;
      allow update, delete: if false;
    }
  }
}
